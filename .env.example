# LOFI 247 — copy to .env and fill in real values. NEVER commit .env.

# --- X (Twitter) RTMP ingest -------------------------------------------------
# Ingest base URL from X Media Studio -> Producer (region-specific endpoint).
# Prefer the RTMPS form — the stream key is the only broadcast credential and
# should not transit plaintext. Plain rtmp://...:80/x works as a fallback.
X_RTMP_URL=rtmps://va.pscp.tv:443/x
# Stream key from X Media Studio. Treat like a password — anyone with it can
# broadcast to your account.
X_STREAM_KEY=your-x-stream-key

# --- Icecast -----------------------------------------------------------------
# Password liquidsoap uses to publish the /radio mount (internal only).
ICECAST_SOURCE_PASSWORD=change-me-source
# Password for the icecast admin interface (internal only).
ICECAST_ADMIN_PASSWORD=change-me-admin

# --- Stream output -----------------------------------------------------------
# Output canvas size for the RTMP video.
STREAM_WIDTH=1280
STREAM_HEIGHT=720
# Output framerate.
STREAM_FPS=30
# x264 target/max bitrate (keep the k suffix).
VIDEO_BITRATE=3500k
# AAC audio bitrate for the RTMP stream (keep the k suffix).
AUDIO_BITRATE=160k

# --- Branding overlay --------------------------------------------------------
# Station name shown in the on-screen bug and icecast metadata.
STATION_NAME="LOFI 247"
# Handle shown next to the station name in the top-right bug.
OVERLAY_HANDLE="@yourhandle"

# --- slskd (optional; only used with: docker compose --profile acquire up -d)
# Login for the slskd web UI (bound to 127.0.0.1:5030 — reach it through an
# SSH tunnel: ssh -L 5030:localhost:5030 <user>@<vps>). SLSKD_PASSWORD is
# MANDATORY before starting the acquire profile: it guards your Soulseek
# credentials. Use a long random value.
SLSKD_USERNAME=slskd
SLSKD_PASSWORD=change-me-slskd
# Your Soulseek network account credentials.
SLSKD_SLSK_USERNAME=your-soulseek-username
SLSKD_SLSK_PASSWORD=your-soulseek-password
